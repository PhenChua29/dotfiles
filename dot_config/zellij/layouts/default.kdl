layout {
    pane split_direction="vertical" {
        pane
    }

    pane size=1 borderless=true {
        plugin location="https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm" {
            format_left  "#[bg=#181825]"
            format_center "{tabs}"
            format_space "#[bg=#181825]"
            format_right "{mode}"

            mode_normal            "#[bg=#89ca78] "
            mode_tmux              "#[bg=#ffc387] "
            mode_default_to_mode "tmux"

            tab_normal               "#[fg=#6C7086,bg=#181825] {name} {fullscreen_indicator}{sync_indicator}{floating_indicator}"
            tab_active               "#[fg=#89ca78,bg=#181825] {name} {fullscreen_indicator}{sync_indicator}{floating_indicator}"
            tab_separator           "#[fg=#6C7086,bg=#181825] | "
            tab_fullscreen_indicator "□ "
            tab_sync_indicator       "  "
            tab_floating_indicator   "󰉈 "

            hide_frame_for_single_pane "false"
        }
    }
}
